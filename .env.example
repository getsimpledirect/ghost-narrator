# ═══════════════════════════════════════════════════════════════════════════════
# Ghost Narrator - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Server Configuration ──────────────────────────────────────────────────────
# External IP address of your VM (used for webhook URLs)
SERVER_EXTERNAL_IP=your-vm-external-ip

# Timezone for n8n (IANA format)
TIMEZONE=UTC

# ─── n8n Configuration ─────────────────────────────────────────────────────────
# Admin credentials for n8n web interface
N8N_USER=admin
N8N_PASSWORD=your-secure-password-here

# Encryption key for n8n (generate with: openssl rand -hex 32)
N8N_ENCRYPTION_KEY=your-encryption-key-here

# ─── LLM Backend ───────────────────────────────────────────────────────────────
# install.sh sets these automatically based on GPU detection:
#   GPU detected (mid_vram / high_vram) → COMPOSE_PROFILES=gpu, LLM_BASE_URL=http://vllm:8000/v1
#   No GPU (cpu_only / low_vram)        → COMPOSE_PROFILES=cpu, LLM_BASE_URL=http://ollama:11434/v1
# Override LLM_BASE_URL to use any external OpenAI-compatible API instead.
COMPOSE_PROFILES=cpu

# ─── TTS Service Configuration ─────────────────────────────────────────────────
# Device for TTS inference: cpu or cuda (cuda recommended for L4/T4 GPUs)
TTS_DEVICE=cuda

# Voice reference text - exact transcript of your reference.wav (optional)
# When set: uses ICL (in-context learning) mode for higher-quality voice cloning
# When blank: uses x-vector-only mode (no transcript needed - recommended default)
VOICE_SAMPLE_REF_TEXT=

# Number of worker threads for parallel processing
MAX_WORKERS=4

# Maximum words per chunk
MAX_CHUNK_WORDS=200

# TTS output language (default: auto-detect). Override for non-English voices: zh, ja, de, fr, etc.
# TTS_LANGUAGE=auto

# Segment synthesis — leave blank to auto-probe from VRAM at startup (recommended)
# Override only to pin a fixed segment size regardless of available VRAM.
# SINGLE_SHOT_SEGMENT_WORDS=
# SINGLE_SHOT_MAX_WORDS=400
# SINGLE_SHOT_OVERLAP_MS=500

# ─── Hardware Detection ────────────────────────────────────────────────────────
# Override auto-detection. Leave blank for automatic. Values: cpu_only, low_vram, mid_vram, high_vram
HARDWARE_TIER=

# ─── Narration LLM ─────────────────────────────────────────────────────────────
# Set by install.sh — see LLM Backend section above.
LLM_BASE_URL=http://ollama:11434/v1

# Override model name (default: auto-selected from hardware tier)
LLM_MODEL_NAME=

# Override LLM context window size (default: auto-selected from hardware tier)
# HIGH_VRAM default: 65536 (64K). Reduce to 32768 to free VRAM at the cost of
# single-shot threshold (8000 words → 5000 words).
SELECTED_LLM_NUM_CTX=

# ─── Storage Backend ───────────────────────────────────────────────────────────
# Options: local (default), gcs, s3
STORAGE_BACKEND=local

# GCS (if STORAGE_BACKEND=gcs)
# GCS_BUCKET_NAME=your-gcs-bucket
# GCS_AUDIO_PREFIX=audio/articles
# GCS_SERVICE_ACCOUNT_KEY_PATH=

# AWS S3 (if STORAGE_BACKEND=s3)
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=your-s3-bucket
# S3_AUDIO_PREFIX=audio/articles

# ─── Audio Quality Override ─────────────────────────────────────────────────────
# Leave blank to use tier defaults (recommended)
# MP3_BITRATE=192k
# AUDIO_SAMPLE_RATE=44100
# TARGET_LUFS=-16.0

# Acoustic quality gate mode (default: false = enforce).
# Set to true for shadow/calibration mode — logs gate failures but passes all segments through.
# DRY_RUN_GATE=false

# ─── Redis Configuration ───────────────────────────────────────────────────────
# Job TTL in seconds (default: 86400 = 24 hours)
REDIS_JOB_TTL=86400

# Maximum wall-clock time a job may run before it is killed and marked failed (default: 8 hours)
# Increase for very long articles (>6000 words) on slow hardware.
# MAX_JOB_DURATION_SECONDS=28800

# Redis password (auto-generated by install.sh - DO NOT SET MANUALLY)
REDIS_PASSWORD=

# ─── TTS Service Security ───────────────────────────────────────────────────────
# API key for TTS service (generate with: openssl rand -hex 32)
TTS_API_KEY=

# LLM API key (default: 'ollama' for bundled Ollama)
LLM_API_KEY=ollama

# Trusted proxy count for rate limiter (0 = no X-Forwarded-For trust)
TRUSTED_PROXY_COUNT=0

# ─── Logging ───────────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# LOG_LEVEL=INFO
# Log format: '' (default text), 'json' (structured for log aggregators), 'console' (coloured)
# LOG_FORMAT=

# ─── LLM Configuration ─────────────────────────────────────────────────────────
# Client-side LLM timeout in seconds.
# vLLM: no server-side timeout; client timeout is a safety valve (default 300s).
# Ollama: stream=True bypasses the 120s idle timeout; 300s is the safe value.
LLM_TIMEOUT=300

# Completeness-check LLM call timeout in seconds (default: 360)
LLM_COMPLETENESS_TIMEOUT=360

# ─── Webhook Security ───────────────────────────────────────────────────────────
# HMAC secret for Ghost → n8n webhook validation (generate with: openssl rand -hex 32)
N8N_GHOST_WEBHOOK_SECRET=

# ─── Ghost API Keys ───────────────────────────────────────────────────────────
# Ghost Site 1
GHOST_SITE1_URL=https://ghost.your-site-1.com
GHOST_KEY_SITE1=your-content-api-key-here
GHOST_SITE1_ADMIN_API_KEY=your-admin-api-key-here

# Ghost Site 2
GHOST_SITE2_URL=https://ghost.your-site-2.com
GHOST_KEY_SITE2=your-content-api-key-here
GHOST_SITE2_ADMIN_API_KEY=your-admin-api-key-here

# ═══════════════════════════════════════════════════════════════════════════════
# NOTES
# ═══════════════════════════════════════════════════════════════════════════════
#
# Ghost Site URLs (REQUIRED for multi-site support):
#   GHOST_SITE1_URL and GHOST_SITE2_URL are REQUIRED for the workflow to
#   automatically detect which Ghost site a post belongs to. The workflow
#   matches the incoming webhook's post URL hostname against these values.
#
# Voice Sample:
#   Place your voice reference file at:
#     tts-service/voices/reference.wav
#   This should be a 30-60 second WAV file of clear speech.
#
# GCS Authentication:
#   The TTS service uses Application Default Credentials (ADC).
#   On GCE VMs, attach a service account with Storage Object Admin role.
#   Locally, run: gcloud auth application-default login
#
# ═══════════════════════════════════════════════════════════════════════════════
