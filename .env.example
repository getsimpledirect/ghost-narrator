# ═══════════════════════════════════════════════════════════════════════════════
# Ghost Narrator - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Server Configuration ──────────────────────────────────────────────────────
# External IP address of your VM (used for webhook URLs)
SERVER_EXTERNAL_IP=your-vm-external-ip

# Timezone for n8n (IANA format)
TIMEZONE=UTC

# ─── n8n Configuration ─────────────────────────────────────────────────────────
# Admin credentials for n8n web interface
N8N_USER=admin
N8N_PASSWORD=your-secure-password-here

# Encryption key for n8n (generate with: openssl rand -hex 32)
N8N_ENCRYPTION_KEY=your-encryption-key-here

# ─── vLLM / LLM Configuration ─────────────────────────────────────────────────
# External vLLM endpoint — only needed if overriding the bundled Ollama LLM
# VLLM_BASE_URL=http://host.docker.internal:8001/v1
# VLLM_MODEL_NAME=Qwen/Qwen3-14B-AWQ

# ─── TTS Service Configuration ─────────────────────────────────────────────────
# Device for TTS inference: cpu or cuda (cuda recommended for L4/T4 GPUs)
TTS_DEVICE=cuda

# Number of worker threads for parallel processing
MAX_WORKERS=4

# Maximum words per chunk
MAX_CHUNK_WORDS=200

# ─── Hardware Detection ────────────────────────────────────────────────────────
# Override auto-detection. Leave blank for automatic. Values: cpu_only, low_vram, mid_vram, high_vram
HARDWARE_TIER=

# ─── Narration LLM ─────────────────────────────────────────────────────────────
# Default: bundled Ollama (http://ollama:11434/v1)
# Override to use external vLLM: http://host.docker.internal:8001/v1
LLM_BASE_URL=http://ollama:11434/v1

# Override model name (default: auto-selected from hardware tier)
LLM_MODEL_NAME=

# ─── Storage Backend ───────────────────────────────────────────────────────────
# Options: local (default), gcs, s3
STORAGE_BACKEND=local

# GCS (if STORAGE_BACKEND=gcs)
# GCS_BUCKET_NAME=your-gcs-bucket
# GCS_AUDIO_PREFIX=audio/articles
# GCS_SERVICE_ACCOUNT_KEY_PATH=

# AWS S3 (if STORAGE_BACKEND=s3)
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=your-s3-bucket
# S3_AUDIO_PREFIX=audio/articles

# ─── Audio Quality Override ─────────────────────────────────────────────────────
# Leave blank to use tier defaults (recommended)
# MP3_BITRATE=192k
# AUDIO_SAMPLE_RATE=44100
# TARGET_LUFS=-16.0

# ─── Redis Configuration ───────────────────────────────────────────────────────
# Job TTL in seconds (default: 86400 = 24 hours)
REDIS_JOB_TTL=86400

# ─── Ghost API Keys ───────────────────────────────────────────────────────────
# Ghost Site 1
GHOST_SITE1_URL=https://ghost.your-site-1.com
GHOST_KEY_SITE1=your-content-api-key-here
GHOST_SITE1_ADMIN_API_KEY=your-admin-api-key-here

# Ghost Site 2
GHOST_SITE2_URL=https://ghost.your-site-2.com
GHOST_KEY_SITE2=your-content-api-key-here
GHOST_SITE2_ADMIN_API_KEY=your-admin-api-key-here

# ═══════════════════════════════════════════════════════════════════════════════
# NOTES
# ═══════════════════════════════════════════════════════════════════════════════
#
# Ghost Site URLs (REQUIRED for multi-site support):
#   GHOST_SITE1_URL and GHOST_SITE2_URL are REQUIRED for the workflow to
#   automatically detect which Ghost site a post belongs to. The workflow
#   matches the incoming webhook's post URL hostname against these values.
#
# Voice Sample:
#   Place your voice reference file at:
#     tts-service/voices/reference.wav
#   This should be a 30-60 second WAV file of clear speech.
#
# GCS Authentication:
#   The TTS service uses Application Default Credentials (ADC).
#   On GCE VMs, attach a service account with Storage Object Admin role.
#   Locally, run: gcloud auth application-default login
#
# ═══════════════════════════════════════════════════════════════════════════════
