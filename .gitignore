# ═══════════════════════════════════════════════════════════════════════════════
# Ghost Narrator - Git Ignore Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# ─── SECRETS — never commit these ─────────────────────────────────────────────
.env
.env.*
!.env.example
*.env.local
secrets/
*.json.key
*.pem
*.key

# ─── Voice samples (biometric data — keep off version control) ────────────────
tts-service/voices/*
!tts-service/voices/.gitkeep
!tts-service/voices/profiles/
!tts-service/voices/profiles/.gitkeep
!tts-service/voices/default/
!tts-service/voices/default/.gitkeep

# Voice profiles (may contain sensitive voice data)
tts-service/voices/profiles/*.wav
tts-service/voices/default/reference.wav

# Hardware probe output
shared/

# ─── Runtime data ─────────────────────────────────────────────────────────────
tts-service/output/
n8n/data/

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.venv/
venv/
ENV/
env/

# ─── Docker ───────────────────────────────────────────────────────────────────
*.log
docker-compose.override.yml

# ─── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.tmp
*.temp
*.bak

# ─── Git Worktrees ────────────────────────────────────────────────────────────
.worktrees/

# ─── AI coding tools — never commit ──────────────────────────────────────────
docs/superpowers/
CLAUDE.md
AGENTS.md
AGENT.md
.claude/
.code-review-graph/
.claude.local.md
graphify-out/
.opencode/
.swarm/
.claude-flow/

# ─── Model weights / checkpoints ───────────────────────────────────────────────
*.pt
*.bin
*.ckpt
*.safetensors
checkpoints/

# ─── Test / Coverage ──────────────────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
.ruff_cache/
.tox/
.hypothesis/
